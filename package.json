{
  "name": "vue-calendarium",
  "version": "1.0.3",
  "description": "A polished, full-featured scheduling and calendar component for Vue 3 and Vuetify, with Temporal API date handling, recurring events (RRULE), i18n and mobile gestures",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js"
    }
  },
  "files": [
    "src",
    "docs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.vue",
    "test": "vitest run tests/unit",
    "test:ui": "playwright test",
    "test:ui:headed": "playwright test --headed",
    "test:ui:debug": "playwright test --debug",
    "test:ui:report": "playwright show-report"
  },
  "keywords": [
    "vue",
    "vue3",
    "vuetify",
    "calendar",
    "scheduler",
    "events",
    "rrule",
    "temporal",
    "i18n"
  ],
  "author": "zehenrique <10810709+zehenrique@users.noreply.github.com>",
  "license": "MIT",
  "homepage": "https://github.com/zehenrique/vue-calendarium#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zehenrique/vue-calendarium.git"
  },
  "bugs": {
    "url": "https://github.com/zehenrique/vue-calendarium/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "peerDependencies": {
    "vue": "^3.3.0",
    "vue-i18n": "^11.0.0",
    "vuetify": "^3.3.0"
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "@mdi/font": "^7.4.47",
    "hammerjs": "^2.0.8",
    "ical.js": "^2.1.0",
    "rrule": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.56.1",
    "@vitejs/plugin-vue": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "playwright": "^1.56.1",
    "vite": "^8.1.3",
    "vitest": "^4.0.16",
    "vue": "^3.3.0",
    "vue-i18n": "^11.4.6",
    "vuetify": "^3.12.8"
  }
}
